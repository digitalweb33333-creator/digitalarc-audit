# ============================================================
# digitalarc-audit — variables d'environnement (copier en .env)
# ============================================================

# --- GARDE-FOUS (laisser false jusqu'au feu vert "LANCE") ---
# false = aucun appel externe (Firecrawl/Claude/SMTP/Make), tout est simulé
AUDIT_LIVE=false
# false = même en LIVE, l'audit n'est PAS envoyé au prospect (seulement à NOTIFY_EMAIL)
AUDIT_SEND_TO_PROSPECT=false

# --- Serveur webhook (ÉTAPE 1) ---
WEBHOOK_PORT=3000
WEBHOOK_PATH=/webhook/audit
# Secret partagé optionnel (à mettre aussi dans l'action Webhook Elementor)
WEBHOOK_SECRET=

# --- Firecrawl (scrape du site prospect) ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Claude / Anthropic (génération de l'audit) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# --- SMTP Hostinger (envoi de l'audit) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@digitalarc.fr
SMTP_PASS=
SENDER_NAME=Joachim - Digitalarc
SENDER_WEBSITE=https://digitalarc.fr
SENDER_REPLY_TO=contact@digitalarc.fr
# Reçoit chaque audit pour relecture
NOTIFY_EMAIL=joachim33333@outlook.fr

# --- Make (log CRM des demandes d'audit) — optionnel ---
MAKE_WEBHOOK_AUDIT=
